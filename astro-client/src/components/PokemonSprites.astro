---
const { sprites, pokemonName } = Astro.props;
---

<div class="sprites">

  <h3>Official Artwork</h3>
  <div class="row">
    {sprites.official.default && <img src={sprites.official.default} alt={`Official artwork of ${pokemonName}`} loading="lazy"/>}
    {sprites.official.shiny && <img src={sprites.official.shiny} alt={`${pokemonName} - official artwork (shiny)`} loading="lazy"/>}
  </div>

  <h3>Home</h3>
  <div class="row">
    {sprites.home.default && <img src={sprites.home.default} alt={`${pokemonName} - Home sprite`} loading="lazy"/>}
    {sprites.home.shiny && <img src={sprites.home.shiny} alt={`${pokemonName} - Home sprite (shiny)`} loading="lazy"/>}
  </div>
  
  <h3>Showdown</h3>
  <div class="row">
    {sprites.showdown.default && <img src={sprites.showdown.default} alt={`${pokemonName} - Showdown sprite`} loading="lazy"/>}
    {sprites.showdown.shiny && <img src={sprites.showdown.shiny} alt={`${pokemonName} - Showdown sprite (shiny)`} loading="lazy"/>}
  </div>

  <h3>Default Game Sprites</h3>
  <div class="row">
    {sprites.default.default && <img src={sprites.default.default} alt={`${pokemonName} - game sprite`} loading="lazy"/>}
    {sprites.default.shiny && <img src={sprites.default.shiny} alt={`${pokemonName} - game sprite (shiny)`} loading="lazy"/>}
  </div>

  {Object.keys(sprites.variants).length > 0 && (
    <>
      <h3>Regional / Form Variants</h3>
      <div class="variants">
        {Object.entries(sprites.variants).map(([form, v]) => (
          <div class="variant">
            <h4>{form}</h4>
            {v.default && <img src={v.default} alt={`${pokemonName} - ${form} form`} loading="lazy"/>}
            {v.shiny && <img src={v.shiny} alt={`${pokemonName} - ${form} form (shiny)`} loading="lazy"/>}
          </div>
        ))}
      </div>
    </>
  )}
</div>

<style>
  .row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  img {
    width: 128px;
    image-rendering: pixelated;
  }
  .variants {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
  }
  .variant {
    text-align: center;
  }
</style>
